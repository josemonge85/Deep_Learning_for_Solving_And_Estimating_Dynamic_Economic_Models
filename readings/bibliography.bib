@incollection{DIETZ20241,
title = {Chapter 1 - Introduction to integrated assessment modeling of climate change},
editor = {Lint Barrage and Solomon Hsiang},
series = {Handbook of the Economics of Climate Change},
publisher = {North-Holland},
volume = {1},
number = {1},
pages = {1--51},
year = {2024},
issn = {3050-7294},
doi = {https://doi.org/10.1016/bs.hesecc.2024.10.002},
url = {https://www.sciencedirect.com/science/article/pii/S3050729424000023},
author = {Simon Dietz},
keywords = {Integrated assessment models, Greenhouse gas emissions, Climate change externality, Social cost of carbon, Climate policy, Damages, Discount rate, Uncertainty},
abstract = {This chapter provides an introduction to and overview of climate-economic modeling, in particular the class of Integrated Assessment Models (IAMs) built to answer arguably the primary questions in climate economics: how big is the climate externality, how much will it cost to internalize it, and what pathway of global greenhouse gas emissions and emissions prices maximizes welfare? It is no easy task. The chapter describes the main components of an IAM, including important choices about model structure and associated challenges in calibrating and estimating the model. The literature is reviewed from pioneering studies up to the present day, highlighting the main findings, critiques, and research avenues pursued. IAMs have become more numerous and heterogeneous over the past decade or so: a central purpose of this chapter is to provide an account of how and why this has happened and an overview of how the field now looks.},
}

